# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Secrets
*.pem
*.key
*.secret
.env*
kubeconfig*
*.kubeconfig
# Go sources like bootstrap/internal/talos/kubeconfig.go are code, not credentials
!kubeconfig*.go

# Bootstrap runtime state — plaintext working cache (regenerable).
# The encrypted vault/ under each cluster is committed; only the decrypted
# working copies are ignored.
clusters/*/secrets/
clusters/*/nodes/
clusters/*/state/
clusters/*/*.log
logs/

# Superpowers working docs (plans/specs are local scratch, not repo artifacts)
docs/superpowers/
