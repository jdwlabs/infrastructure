# Proxmox Connection
proxmox_endpoint         = "https://192.168.1.100:8006/api2/json"
proxmox_api_token_id     = "terraform@pve!token-name"
proxmox_api_token_secret = "your-token-secret"

# Infrastructure
storage_pool = "local-lvm"
talos_iso    = "local:iso/nocloud-amd64.iso"

# Cluster Configuration (used by Go bootstrap tool)
cluster_name           = "cluster"
control_plane_endpoint = "cluster.example.com"
haproxy_ip             = "192.168.1.10"
kubernetes_version     = "v1.35.1"
talos_version          = "v1.13.4"
installer_image        = "ghcr.io/siderolabs/installer:v1.13.4"

haproxy_login_user     = "root"
haproxy_stats_user     = "admin"
haproxy_stats_password = "your-password"

# Restrict the k8s/talos apiserver frontends to these source CIDRs.
# Leave empty ([]) to keep them reachable from anywhere (current default).
admin_allowed_cidrs = []

# Ingress NodePorts (e.g. NGINX Gateway Fabric uses 30180/30543 by default,
# ingress-nginx uses 30080/30443). HAProxy forwards :80/:443 to these ports.
ingress_http_nodeport = 30180
ingress_tls_nodeport  = 30543

proxmox_node_ips = {
  "pve1" = "192.168.1.100"
}

# Control Plane Nodes
talos_control_configuration = [
  {
    node_name = "pve1"
    vm_name   = "talos-cp-1"
    vmid      = 201
    cpu_cores = 4
    memory    = 4096
    disk_size = 50
  },
]

# Worker Nodes
# Sizing guidance:
# - Prefer fewer, larger workers over many small ones: a 4096 MiB worker
#   keeps only ~1-2 GiB schedulable after system reserve, so placement (not
#   total capacity) becomes the binding constraint.
# - Longhorn stores replicas on the worker's own disk: a new worker's
#   disk_size must match or exceed the Longhorn-exposed capacity of any
#   worker it is meant to replace, or replica rebuilds will not fit.
# - On hosts shared with non-Talos VMs (GPU inference, CI runners), keep the
#   sum of all dedicated `memory` below host RAM minus the co-tenant
#   reservation — Proxmox dedicated memory is not reclaimed while a VM runs.
talos_worker_configuration = [
  {
    node_name = "pve1"
    vm_name   = "talos-worker-1"
    vmid      = 301
    cpu_cores = 4
    memory    = 8192
    disk_size = 100
  },
  {
    node_name = "pve2"
    vm_name   = "talos-worker-2"
    vmid      = 302
    cpu_cores = 6
    memory    = 16384
    disk_size = 200
  },
]

# GPU inference VM (AI-SRE local tier)
gpu_vm_ssh_public_key = "ssh-ed25519 AAAA... you@host"
